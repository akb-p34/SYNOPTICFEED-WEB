# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local.

# Supabase (from Supabase dashboard → Project Settings → API)
SUPABASE_URL=https://REPLACE_ME.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME_SERVICE_ROLE_KEY

# Resend (from resend.com → API Keys)
RESEND_API_KEY=re_REPLACE_ME

# Where founding-partner notifications go
NOTIFY_TO_EMAIL=akbar.pathan034@gmail.com

# Where welcome emails come from (must be a verified sender on your domain)
RESEND_FROM_EMAIL="SynopticFeed <founding@synopticfeed.com>"
